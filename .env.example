# ============================================================================
# admin-console — environment variables (root)
# Copy to .env and adjust. `.env` is gitignored.
# ============================================================================

# --- Postgres (shared by app + Keycloak) -----------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin_console
POSTGRES_PASSWORD=admin_console
POSTGRES_DB=admin_console

# Prisma consumes this directly.
# Server-only. Never expose to the browser.
DATABASE_URL=postgresql://admin_console:admin_console@localhost:5432/admin_console?schema=public

# --- Auth (Google OIDC via Auth.js v5) -------------------------------------
# Get credentials from https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" of type "Web application" and add
# http://localhost:3000/api/auth/callback/google to authorized redirect URIs.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Auth.js session encryption secret — generate with: openssl rand -base64 32
# AUTH_SECRET=

# --- Keycloak (optional — disabled in core; enable for on-prem deployments)
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# KEYCLOAK_PORT=8080
# KC_DB_NAME=keycloak
# KEYCLOAK_ISSUER=http://localhost:8080/realms/admin-console
# KEYCLOAK_CLIENT_ID=admin-web
# KEYCLOAK_CLIENT_SECRET=

# --- API (NestJS) ----------------------------------------------------------
API_PORT=3001
# Server-only. BFF (admin) reads API_URL to proxy calls.
API_URL=http://localhost:3001
