# ============================================================================
# admin-console — environment variables (root)
# Copy to .env and adjust. `.env` is gitignored.
# ============================================================================

# --- Postgres (shared by app + Keycloak) -----------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin_console
POSTGRES_PASSWORD=admin_console
POSTGRES_DB=admin_console

# Prisma consumes this directly.
# Server-only. Never expose to the browser.
DATABASE_URL=postgresql://admin_console:admin_console@localhost:5432/admin_console?schema=public

# --- Keycloak ---------------------------------------------------------------
# Admin console bootstrap credentials (first boot only; change after).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080
KC_DB_NAME=keycloak

# OIDC client settings (populated when realm is imported in Step 9).
# KEYCLOAK_ISSUER=http://localhost:8080/realms/admin-console
# KEYCLOAK_CLIENT_ID=admin-web
# KEYCLOAK_CLIENT_SECRET=

# --- API (NestJS) ----------------------------------------------------------
API_PORT=3001
# Server-only. BFF (admin) reads API_URL to proxy calls.
API_URL=http://localhost:3001

# --- Admin (Next.js) -------------------------------------------------------
# Auth.js secret — generate with: openssl rand -base64 32
# AUTH_SECRET=
